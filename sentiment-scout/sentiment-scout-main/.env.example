# Sentiment Scout — environment variables.
# Copy this file to .env (gitignored) and fill in real values. The app reads
# these via config.py / dashboard.py; missing required keys fail loudly.

# ── Required secrets ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=        # OpenRouter API key for the AI ranking (sentiment_screener)
FINVIZ_TOKEN=              # Finviz Elite auth token — screener, multicap, charts, correlation
SENTIMENT_SCOUT_API_KEYS=  # comma-separated keys for the /api/v1 public API

# ── Deployment (every var defaults to current local behavior — leave unset for
#    local dev) ─────────────────────────────────────────────────────────────
MONGO_URI=                 # MongoDB connection string (default: mongodb://localhost:27017).
                           #   Set to a MongoDB Atlas SRV URI on a deployed host.
FRONTEND_ORIGIN=           # backend CORS allowlist, comma-separated (default: http://localhost:5173).
                           #   Set to the deployed frontend origin, e.g. https://sentiment-scout.vercel.app
VAR_ROOT=                  # runtime/writable data dir (default: ./var). Point at a
                           #   mounted persistent volume on a host, e.g. /app/var (Docker).

# ── Bluesky social source (optional — unset = source cleanly disabled) ───────
# Prefer setting these via Settings → Credentials (encrypted store); env works too.
# The app password is NOT your account password — create one at
# bsky.app → Settings → App Passwords.
BLUESKY_HANDLE=            # e.g. you.bsky.social
BLUESKY_APP_PASSWORD=      # Bluesky app password (xxxx-xxxx-xxxx-xxxx)

# Reddit social source (optional — unset = source cleanly disabled). App-only
# OAuth: create a "script" app at reddit.com/prefs/apps for the id + secret.
REDDIT_CLIENT_ID=          # Reddit app client ID
REDDIT_CLIENT_SECRET=      # Reddit app client secret
REDDIT_USER_AGENT=         # e.g. sentiment-scout/1.0 by u/yourname

# VITE_API_BASE is a *frontend build-time* var (read by Vite, not the backend) —
# set it in the Vercel project env, NOT in this file. It is the public backend URL
# the built bundle calls (e.g. https://api.example.com). Unset in local dev → the
# bundle uses the relative /api path via the Vite proxy.
# VITE_API_BASE=

# ── Optional path overrides (repo-relative defaults; leave unset normally) ───
FEEDFLASH_ROOT=            # vendored FeedFlash code dir (default: external/feedflash)
FEEDFLASH_DB=              # writable FeedFlash DB (default: <VAR_ROOT>/feedflash/feedflash.db)
YOSEF_ROOT=                # vendored Yosef code dir (default: external/yosef)
YOSEF_FINVIZ_CSV=          # writable Yosef ticker CSV (default: <VAR_ROOT>/yosef/yosef_finviz_input.csv)
