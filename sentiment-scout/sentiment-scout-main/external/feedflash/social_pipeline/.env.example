# ── MongoDB Atlas ──────────────────────────────────────────────────
# SRV connection string from Atlas → Connect → Drivers
# Format: mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ds440
MONGO_COLLECTION=posts

# ── Bluesky (AT Protocol) ────────────────────────────────────────
# Create an app password at: Settings → App Passwords in bsky.app
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# ── Redis / Upstash (Python pipeline uses TCP) ───────────────────
# From Upstash console → Redis → Details → copy the "redis://" URI
# IMPORTANT: Use rediss:// (two s's) for TLS — required by Upstash
# Format: rediss://default:PASSWORD@ENDPOINT.upstash.io:6379
# NOTE: The dashboard uses a DIFFERENT protocol (REST API) — see
#       dashboard/.env.example for UPSTASH_REDIS_REST_URL and token.
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# ── PostgreSQL / Neon ─────────────────────────────────────────────
# From Neon console → Connection Details → copy the connection string
# sslmode=require is mandatory for Neon
POSTGRES_DSN=postgresql://user:password@your-endpoint.neon.tech/ds440?sslmode=require

# ── Interactive Brokers TWS/Gateway (optional) ───────────────────
# The IB news scraper requires TWS or IB Gateway running LOCALLY.
# It CANNOT run in GitHub Actions — IB_ENABLED must be false in CI.
#
# Ports:
#   7497 → Paper trading TWS    (recommended for testing)
#   7496 → Live trading TWS
#   4002 → Paper trading Gateway (headless, for servers)
#   4001 → Live trading Gateway
#
# clientId: use a number not already in use by your manual TWS session.
# The default of 10 avoids conflicting with TWS's own client (usually 1).
#
# Enable in TWS: Edit → Global Configuration → API → Settings
#   ✓ Enable ActiveX and Socket Clients
#   ✓ Add 127.0.0.1 to Trusted IPs
IB_ENABLED=false
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=10
# Comma-separated fallback tickers used when Redis active_tickers is empty
IB_TICKERS_FALLBACK=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,SPY,QQQ,AMD
# How far back to look for news on each cycle
IB_LOOKBACK_HOURS=24
# Max tickers to process per cycle (keeps each run under ~2 minutes)
IB_MAX_TICKERS=50
# Max headlines fetched per ticker (IB hard cap is 300)
IB_HEADLINES_PER_TICKER=50
# Set to true to also fetch article body text (costs extra IB API quota)
IB_FETCH_ARTICLE_BODY=false

# ── FinBERT Sentiment Service (optional) ─────────────────────────
# URL of the deployed sentiment_service/service.py (Railway / Render / fly.io)
# If not set, articles use DS440 rule-based sentiment only (scored during fetch)
SENTIMENT_SERVICE_URL=https://your-sentiment-service.railway.app
