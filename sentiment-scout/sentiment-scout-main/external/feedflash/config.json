    "fetch_body": false,
    "category": "markets"
  },
  "schwab": {
    "enabled": false,
    "client_id": "",
    "client_secret": "",
    "refresh_token": "",
    "news_endpoint": "",
    "fetch_limit": 50,
    "category": "markets"
  },
  "finviz": {
    "enabled": false,
    "elite": false,
    "email": "",
    "password": "",
    "watch_interval_sec": 10,
    "category": "markets"
  },
  "tradingview": {
    "enabled": true,
    "symbol": "",
    "fetch_limit": 50,
    "category": "markets"
  },
  "impersonation": {
    "enabled": true,
    "preferred_browser": "chrome",
    "max_retries": 3,
    "backoff_base_ms": 500,
    "backoff_max_ms": 30000,
    "timeout_seconds": 30,
    "connect_timeout_seconds": 10,
    "follow_redirects": true,
    "max_redirects": 5,
    "verbose": false,
    "cookie_jar": "",
    "curl_impersonate_path": ""
  },
