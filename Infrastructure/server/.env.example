# FeedFlash backend environment template.
# Copy to .env for local development and fill only the values you need.

# Optional AI/sentiment provider key. Leave blank unless enabled.
ANTHROPIC_API_KEY=

# MongoDB connection. Local development can use the default Docker/local URI.
MONGODB_URI=mongodb://localhost:27017/feedflash
MONGO_DB=feedflash
MONGODB_DB=feedflash

# Hosted MongoDB example shape only. Do not commit real credentials:
# MONGODB_URI=<your-hosted-mongodb-uri>

PORT=3001

# Optional source credentials. Leave blank unless you have access.
FINVIZ_AUTH_TOKEN=
FINVIZ_TOKEN=
FINVIZ_COOKIE=
BENZINGA_API_KEY=
DOW_JONES_API_KEY=
X_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_ACCESS_TOKEN=
SCHWAB_ACCESS_TOKEN=
