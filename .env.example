# ============================================================
# FeedFlash – Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker services (MongoDB, Redis, Kafka, Zookeeper) run
# out of the box with no API keys needed.
# Only fill in API keys below if you want data from paid
# or authenticated sources.
# ============================================================

# ── Server / CORS ──────────────────────────────────────
# Set to * to allow any origin (default for group members).
# For development with Vite on another machine, set to:
#   CORS_ORIGIN=http://192.168.x.x:5173,http://localhost:5173
# For production, set to your actual domain.
CORS_ORIGIN=*
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000

# Optional API protection for production.
# API_TOKEN_SCOPE=write protects POST/PATCH/DELETE API calls.
# API_TOKEN_SCOPE=all also protects read APIs except health checks.
API_TOKEN=
API_TOKEN_SCOPE=write

# ── Fetch / Data Sources ────────────────────────────────
TRADINGVIEW_SCREENER_LIMIT=3000
RSS_FEED_ENTRY_LIMIT=0
ACCESS_NEWSWIRE_PAGE_SIZE=500
DEFAULT_FETCH_MODE=fast

# ── ⚠️  OPTIONAL: API Keys for premium data sources ═══
# These are NOT required for the dashboard to work.
# Leave blank to skip those sources.
# ──────────────────────────────────────────────────────────

# Finviz Elite
# FINVIZ_AUTH_TOKEN=

# Benzinga News
# BENZINGA_API_KEY=

# Dow Jones News
# DOW_JONES_API_KEY=

# X / Twitter API
# X_BEARER_TOKEN=

# Reddit API
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_ACCESS_TOKEN=
# SOCIAL_REDDIT_PUBLIC_FALLBACK=true
# SOCIAL_REDDIT_TIMEOUT=4

# Schwab
# SCHWAB_ACCESS_TOKEN=
# SCHWAB_TRADING_ENABLED=false

# Interactive Brokers News
# IBKR_ENABLE_NEWS=false
# IBKR_HOST=host.docker.internal
# IBKR_PORT=7497
# IBKR_ENABLE_TRADING=false

# Options / Futures APIs
# OPTIONS_API_KEY=
# FUTURES_API_KEY=

# SEC EDGAR
SEC_CONTACT_EMAIL=otisemurray@icloud.com
SEC_USER_AGENT=FeedFlash/1.0 otisemurray@icloud.com

# ── Automation / Safety ───────────────────────────────────
# Auto-refresh runs POST /api/fetch?mode=fast every 60s by default.
# It is serial, non-overlapping, and clamped to at least 60 seconds.
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_MODE=auto
AUTO_REFRESH_INTERVAL_SECONDS=60
AUTO_REFRESH_TIMEOUT_SECONDS=55

# Prevent accidental repeated fetch clicks / overlapping refreshes.
FETCH_MIN_INTERVAL_MS=10000

# Quote enrichment is disabled by default because bulk yfinance was the 56s bottleneck.
ENABLE_QUOTE_FETCH=0
QUOTE_MAX_TICKERS=100

# Optional. Leave blank locally unless the frontend is updated to send this token.
# If set, POST /api/fetch requires X-Admin-Token or Authorization: Bearer.
ADMIN_TOKEN=

# Redis RAM cache TTLs.
CACHE_TTL_SCREENER=20
CACHE_TTL_SOCIAL=15
CACHE_TTL_ARTICLES=15
CACHE_TTL_CHARTS=20
CACHE_TTL_MOMENTUM=15
CACHE_TTL_CORRELATION=30
CACHE_TTL_AI=60
