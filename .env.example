# ============================================================
# FeedFlash – Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker services (MongoDB, Redis, Kafka, Zookeeper) run
# out of the box with no API keys needed.
# Only fill in API keys below if you want data from paid
# or authenticated sources.
# ============================================================

# ── Server / CORS ──────────────────────────────────────
# Set to * to allow any origin (default for group members).
# For development with Vite on another machine, set to:
#   CORS_ORIGIN=http://192.168.x.x:5173,http://localhost:5173
# For production, set to your actual domain.
CORS_ORIGIN=*
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000

# ── Fetch / Data Sources ────────────────────────────────
TRADINGVIEW_SCREENER_LIMIT=3000
DEFAULT_FETCH_MODE=fast

# ── ⚠️  OPTIONAL: API Keys for premium data sources ═══
# These are NOT required for the dashboard to work.
# Leave blank to skip those sources.
# ──────────────────────────────────────────────────────────

# Finviz Elite
# FINVIZ_AUTH_TOKEN=

# Benzinga News
# BENZINGA_API_KEY=

# Dow Jones News
# DOW_JONES_API_KEY=

# X / Twitter API
# X_BEARER_TOKEN=

# Reddit API
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_ACCESS_TOKEN=
# SOCIAL_REDDIT_PUBLIC_FALLBACK=true
# SOCIAL_REDDIT_TIMEOUT=4

# Schwab
# SCHWAB_ACCESS_TOKEN=

# Interactive Brokers News
# IBKR_ENABLE_NEWS=false

# Options / Futures APIs
# OPTIONS_API_KEY=
# FUTURES_API_KEY=

# SEC EDGAR
SEC_USER_AGENT=FeedFlash Research Dashboard