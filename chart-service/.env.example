# chart-service environment (copy to chart-service/.env and fill in; .env is gitignored)
# On Railway, set these as service Variables instead of a .env file.

# ── Finviz Elite auth ─────────────────────────────────────────────────────────
# RECOMMENDED: self-healing login. The service logs into Finviz Elite with these
# credentials, stores the session cookie (which overrides the rotating export
# token), and re-logs in automatically on a 401. No token to rotate by hand.
# Never commit real values — placeholders only.
FINVIZ_LOGIN=
FINVIZ_PASSWORD=

# Legacy static export token. Still accepted (and used as the token in the export
# URL), but it rotates every 1-2 days and eventually 401s. Optional once
# FINVIZ_LOGIN/FINVIZ_PASSWORD are set — the login cookie overrides it.
FINVIZ_TOKEN=

# Where the session-cookie file is persisted (0600). Defaults to <chart-service>/var.
# Point at a mounted volume to keep the cookie across redeploys; otherwise a cold
# start simply logs in again (which is fine).
# VAR_ROOT=/data/chart-service

# Port the Flask service listens on (default 5050).
PORT=5050

# Phase 2b live backfill store (MongoDB). chart-service uses its OWN db/collection
# by default so it stays decoupled. If Mongo is unreachable it falls back to
# in-memory (process-life).
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flashfeed
MONGO_COLL=social_history

# Social overlays — SQLite seed fallback path (gitignored — real data, never commit).
SOCIAL_DB_PATH=

# Comma-separated CORS allowlist for the frontend origin (default: Vite dev).
FRONTEND_ORIGIN=http://localhost:5173

# Optional: TradingView login (paid account) for REAL overnight (20:00-04:00 ET)
# prices via Blue Ocean ATS. Without these the chart falls back to a dashed
# prior-close carry overnight.
TV_USERNAME=
TV_PASSWORD=
